KW_XNOR: /xnor(?![a-zA-Z0-9_$])/
KW_XOR: /xor(?![a-zA-Z0-9_$])/

// SV operator terminals (for genvar iteration)
OP_INC: "++"
OP_DEC: "--"
OP_ADD_ASSIGN: "+="
OP_SUB_ASSIGN: "-="
OP_MUL_ASSIGN: "*="
OP_DIV_ASSIGN: "/="
OP_MOD_ASSIGN: "%="

