KW_SMALL: /small(?![a-zA-Z0-9_$])/
KW_SPECIFY: /specify(?![a-zA-Z0-9_$])/
KW_STRUCT: /struct(?![a-zA-Z0-9_$])/
KW_SPECPARAM: /specparam(?![a-zA-Z0-9_$])/
KW_STRONG0: /strong0(?![a-zA-Z0-9_$])/
KW_STRONG1: /strong1(?![a-zA-Z0-9_$])/
KW_SUPPLY0: /supply0(?![a-zA-Z0-9_$])/
