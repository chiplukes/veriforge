// Lark
QUOTED_IDENTIFIER     : /"((?:.(?!(?<![\\\\])"))*.?)"/
EVERYTHING_UNTIL_WHITESPACE_OR_SEMI_OR_COMMA: /[^\s;,]+/
WORD_BUT_NO_PERIOD: /[^\w;,]+/
COMMENT: "//" /[^\n]*/ NEWLINE
CR              : /\r/
LF              : /\n/
NEWLINE: (CR? LF)
MULTILINE_COMMENT: /\/\*(\*(?!\/)|[^*])*\*\//
ANYTHING: /.+;/

%import common.CNAME
%import common.ESCAPED_STRING
%import common.WS

%ignore WS
%ignore COMMENT
%ignore MULTILINE_COMMENT
%ignore NEWLINE
