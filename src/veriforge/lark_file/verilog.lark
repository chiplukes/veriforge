KW_TRAN: /tran(?![a-zA-Z0-9_$])/
KW_TYPEDEF: /typedef(?![a-zA-Z0-9_$])/
KW_UNION: /union(?![a-zA-Z0-9_$])/
KW_TRANIF0: /tranif0(?![a-zA-Z0-9_$])/
KW_TRANIF1: /tranif1(?![a-zA-Z0-9_$])/
KW_TRI: /tri(?![a-zA-Z0-9_$])/
KW_TRI0: /tri0(?![a-zA-Z0-9_$])/
KW_TRI1: /tri1(?![a-zA-Z0-9_$])/
KW_TRIAND: /triand(?![a-zA-Z0-9_$])/
KW_TRIOR: /trior(?![a-zA-Z0-9_$])/
KW_TRIREG: /trireg(?![a-zA-Z0-9_$])/
